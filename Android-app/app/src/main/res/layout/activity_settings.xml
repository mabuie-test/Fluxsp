<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SettingsActivity"
            android:textSize="22sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbFeatureEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Consentimento permanente da instalação" />

        <TextView
            android:id="@+id/tvConsentState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Consentimento" />

        <TextView
            android:id="@+id/tvSyncState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Sincronização" />

        <Button
            android:id="@+id/btnSyncNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Sincronizar agora" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Campos de teste e compatibilidade"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etProfileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome de perfil" />

        <EditText
            android:id="@+id/etDeviceAlias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Apelido do dispositivo" />

        <EditText
            android:id="@+id/etInternalNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nota interna" />

        <EditText
            android:id="@+id/etSensitiveField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Campo sensível mascarado"
            android:inputType="textPassword" />

        <TextView
            android:id="@+id/tvLocalEntries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Sem registos" />

    </LinearLayout>
</ScrollView>
