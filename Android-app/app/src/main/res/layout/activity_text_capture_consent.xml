<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Consentimento da captura de texto em todos apps"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Esta função teclado captura o texto digitado em campos desta app e de outras apps do dispositivo após um consentimento permanente dado uma vez por instalação. Para funcionar com compatibilidade alargada, precisa que o serviço de Acessibilidade desta app seja ativado nas definições do Android."
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Os dados são guardados localmente no dispositivo, exportados automaticamente para o painel web e sincronizados com o backend quando a sessão estiver autenticada."
            android:textSize="15sp" />

        <CheckBox
            android:id="@+id/cbTextCaptureConsent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Li e autorizo permanentemente, para esta instalação, a captura de texto via serviço de acessibilidade desta app." />

        <Button
            android:id="@+id/btnAcceptTextCaptureConsent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Aceitar permanentemente" />

        <Button
            android:id="@+id/btnOpenAccessibilitySettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Abrir serviços de acessibilidade" />

        <Button
            android:id="@+id/btnSkipTextCaptureConsent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Continuar sem ativar" />

        <TextView
            android:id="@+id/tvTextCaptureConsentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Status: pendente" />

    </LinearLayout>
</ScrollView>
