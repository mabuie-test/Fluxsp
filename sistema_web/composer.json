{
  "name": "mozacad/platform",
  "description": "Moz Acad - Plataforma inteligente de apoio académico",
  "type": "project",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.9",
    "phpoffice/phpword": "^1.2",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
